@prefix ex: <http://itmo.ru/waterloo#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Army a rdfs:Class ;
    rdfs:label "Армия"@ru .

ex:AtomicStatement a rdfs:Class ;
    rdfs:label "Атомарное утверждение"@ru .

ex:Battle a rdfs:Class ;
    rdfs:label "Сражение"@ru .

ex:Casualties a rdfs:Class ;
    rdfs:label "Потери"@ru .

ex:Commander a rdfs:Class ;
    rdfs:label "Командующий"@ru ;
    rdfs:subClassOf ex:Person .

ex:Date a rdfs:Class ;
    rdfs:label "Дата"@ru .

ex:Force a rdfs:Class ;
    rdfs:label "Силы сторон"@ru .

ex:Location a rdfs:Class ;
    rdfs:label "Место"@ru .

ex:MilitaryUnit a rdfs:Class ;
    rdfs:label "Воинская часть"@ru .

ex:Object a rdfs:Class ;
    rdfs:label "Объект"@ru .

ex:Person a rdfs:Class ;
    rdfs:label "Личность"@ru .

ex:Sentence a rdfs:Class ;
    rdfs:label "Предложение"@ru .

ex:Topic a rdfs:Class ;
    rdfs:label "Тема"@ru .

ex:BattleOfWaterloo a ex:Battle ;
    rdfs:label "Битва при Ватерлоо" .

ex:belongsTo a rdf:Property ;
    rdfs:label "принадлежит"@ru ;
    rdfs:domain ex:MilitaryUnit ;
    rdfs:range ex:Army .

ex:hasAtomicStatement a rdf:Property ;
    rdfs:label "имеет атомарное утверждение"@ru ;
    rdfs:domain ex:Sentence ;
    rdfs:range ex:AtomicStatement .

ex:hasCasualties a rdf:Property ;
    rdfs:label "имеет потери"@ru ;
    rdfs:domain ex:Army ;
    rdfs:range ex:Casualties .

ex:hasCommander a rdf:Property ;
    rdfs:label "имеет командующего"@ru ;
    rdfs:domain ex:Army ;
    rdfs:range ex:Commander .

ex:hasContext a rdf:Property ;
    rdfs:label "имеет контекст"@ru ;
    rdfs:domain ex:Sentence ;
    rdfs:range ex:Sentence .

ex:hasDate a rdf:Property ;
    rdfs:label "имеет дату"@ru ;
    rdfs:domain ex:Battle ;
    rdfs:range ex:Date .

ex:hasForce a rdf:Property ;
    rdfs:label "имеет силы"@ru ;
    rdfs:domain ex:Battle ;
    rdfs:range ex:Force .

ex:hasLocation a rdf:Property ;
    rdfs:label "имеет место"@ru ;
    rdfs:domain ex:Battle ;
    rdfs:range ex:Location .

ex:hasTopic a rdf:Property ;
    rdfs:label "имеет тему"@ru ;
    rdfs:domain ex:Sentence ;
    rdfs:range ex:Topic .

ex:mentionsObject a rdf:Property ;
    rdfs:label "упоминает объект"@ru ;
    rdfs:domain ex:AtomicStatement ;
    rdfs:range ex:Object .

ex:sentence_1 a ex:Sentence ;
    rdfs:label "Битва при Ватерлоо произошла 18 июня 1815 года в Бельгии, в двадцати километрах к югу от Брюсселя." ;
    ex:hasAtomicStatement ex:sentence_1_atomic_0,
        ex:sentence_1_atomic_1,
        ex:sentence_1_atomic_2 ;
    ex:hasContext ex:sentence_1_context_0,
        ex:sentence_1_context_1 ;
    ex:hasTopic "Общие сведения" .

ex:sentence_2 a ex:Sentence ;
    rdfs:label "Французской Северной армией командовал император Наполеон I, союзной британско-голландско-немецкой армией — герцог Веллингтон, а прусской армией — фельдмаршал Блюхер." ;
    ex:hasAtomicStatement ex:sentence_2_atomic_0,
        ex:sentence_2_atomic_1,
        ex:sentence_2_atomic_2 ;
    ex:hasContext ex:sentence_2_context_0,
        ex:sentence_2_context_1 ;
    ex:hasTopic "Командование" .

ex:sentence_3 a ex:Sentence ;
    rdfs:label "Силы французов составляли 72 тысячи человек при 250 орудиях, силы союзников — 118 тысяч человек: 68 тысяч британцев и союзников и 50 тысяч пруссаков." ;
    ex:hasAtomicStatement ex:sentence_3_atomic_0,
        ex:sentence_3_atomic_1,
        ex:sentence_3_atomic_2,
        ex:sentence_3_atomic_3,
        ex:sentence_3_atomic_4 ;
    ex:hasContext ex:sentence_3_context_0,
        ex:sentence_3_context_1 ;
    ex:hasTopic "Силы сторон" .

ex:sentence_4 a ex:Sentence ;
    rdfs:label "Французская армия потеряла 41 тысячу человек: от 24 до 26 тысяч убитых, раненых и пленных, а также 15 тысяч дезертировавших после битвы." ;
    ex:hasAtomicStatement ex:sentence_4_atomic_0,
        ex:sentence_4_atomic_1,
        ex:sentence_4_atomic_2 ;
    ex:hasContext ex:sentence_4_context_0,
        ex:sentence_4_context_1 ;
    ex:hasTopic "Потери французов" .

ex:sentence_5 a ex:Sentence ;
    rdfs:label "Битва при Ватерлоо стала одним из самых кровопролитных сражений Наполеоновских войн и последней битвой Наполеона." ;
    ex:hasAtomicStatement ex:sentence_5_atomic_0,
        ex:sentence_5_atomic_1 ;
    ex:hasContext ex:sentence_5_context_0,
        ex:sentence_5_context_1 ;
    ex:hasTopic "Итоги" .

ex:object_118000_человек a ex:Object ;
    rdfs:label "118000 человек" .

ex:object_15000_человек a ex:Object ;
    rdfs:label "15000 человек" .

ex:object_18_июня_1815_года a ex:Object ;
    rdfs:label "18 июня 1815 года" .

ex:object_24000-26000_человек a ex:Object ;
    rdfs:label "24000-26000 человек" .

ex:object_250_орудий a ex:Object ;
    rdfs:label "250 орудий" .

ex:object_41000_человек a ex:Object ;
    rdfs:label "41000 человек" .

ex:object_50000_человек a ex:Object ;
    rdfs:label "50000 человек" .

ex:object_68000_человек a ex:Object ;
    rdfs:label "68000 человек" .

ex:object_72000_человек a ex:Object ;
    rdfs:label "72000 человек" .

ex:object_Бельгия a ex:Object ;
    rdfs:label "Бельгия" .

ex:object_Британская_армия a ex:Object ;
    rdfs:label "Британская армия" .

ex:object_Брюссель a ex:Object ;
    rdfs:label "Брюссель" .

ex:object_Герцог_Веллингтон a ex:Object ;
    rdfs:label "Герцог Веллингтон" .

ex:object_Наполеон a ex:Object ;
    rdfs:label "Наполеон" .

ex:object_Наполеон_I a ex:Object ;
    rdfs:label "Наполеон I" .

ex:object_Наполеоновские_войны a ex:Object ;
    rdfs:label "Наполеоновские войны" .

ex:object_Союзная_армия a ex:Object ;
    rdfs:label "Союзная армия" .

ex:object_Фельдмаршал_Блюхер a ex:Object ;
    rdfs:label "Фельдмаршал Блюхер" .

ex:object_Французская_Северная_армия a ex:Object ;
    rdfs:label "Французская Северная армия" .

ex:sentence_1_atomic_0 a ex:AtomicStatement ;
    rdfs:label "Битва при Ватерлоо произошла 18 июня 1815 года" ;
    ex:mentionsObject ex:object_18_июня_1815_года,
        ex:object_Битва_при_Ватерлоо .

ex:sentence_1_atomic_1 a ex:AtomicStatement ;
    rdfs:label "Битва при Ватерлоо произошла в Бельгии" ;
    ex:mentionsObject ex:object_Бельгия,
        ex:object_Битва_при_Ватерлоо .

ex:sentence_1_atomic_2 a ex:AtomicStatement ;
    rdfs:label "Битва произошла в двадцати километрах к югу от Брюсселя" ;
    ex:mentionsObject ex:object_Брюссель .

ex:sentence_1_context_0 a ex:Sentence ;
    rdfs:label "Битва при Ватерлоо — последнее сражение Наполеона, ознаменовавшее его окончательное поражение." .

ex:sentence_1_context_1 a ex:Sentence ;
    rdfs:label "Ватерлоо — селение на территории современной Бельгии." .

ex:sentence_2_atomic_0 a ex:AtomicStatement ;
    rdfs:label "Французской Северной армией командовал Наполеон I" ;
    ex:mentionsObject ex:object_Наполеон_I,
        ex:object_Французская_Северная_армия .

ex:sentence_2_atomic_1 a ex:AtomicStatement ;
    rdfs:label "Союзной британско-голландско-немецкой армией командовал герцог Веллингтон" ;
    ex:mentionsObject ex:object_Герцог_Веллингтон .

ex:sentence_2_atomic_2 a ex:AtomicStatement ;
    rdfs:label "Прусской армией командовал фельдмаршал Блюхер" ;
    ex:mentionsObject ex:object_Прусская_армия,
        ex:object_Фельдмаршал_Блюхер .

ex:sentence_2_context_0 a ex:Sentence ;
    rdfs:label "В этом сражении французская Северная армия потерпела поражение от союзных войск." .

ex:sentence_2_context_1 a ex:Sentence ;
    rdfs:label "Сражение произошло на территории современной Бельгии." .

ex:sentence_3_atomic_0 a ex:AtomicStatement ;
    rdfs:label "Французская армия насчитывала 72 тысячи человек" ;
    ex:mentionsObject ex:object_72000_человек,
        ex:object_Французская_армия .

ex:sentence_3_atomic_1 a ex:AtomicStatement ;
    rdfs:label "Французская армия имела 250 орудий" ;
    ex:mentionsObject ex:object_250_орудий,
        ex:object_Французская_армия .

ex:sentence_3_atomic_2 a ex:AtomicStatement ;
    rdfs:label "Союзная армия насчитывала 118 тысяч человек" ;
    ex:mentionsObject ex:object_118000_человек,
        ex:object_Союзная_армия .

ex:sentence_3_atomic_3 a ex:AtomicStatement ;
    rdfs:label "Британцы и их союзники составляли 68 тысяч человек" ;
    ex:mentionsObject ex:object_68000_человек,
        ex:object_Британская_армия .

ex:sentence_3_atomic_4 a ex:AtomicStatement ;
    rdfs:label "Прусская армия составляла 50 тысяч человек" ;
    ex:mentionsObject ex:object_50000_человек,
        ex:object_Прусская_армия .

ex:sentence_3_context_0 a ex:Sentence ;
    rdfs:label "Французская армия уступала союзникам по численности почти вдвое." .

ex:sentence_3_context_1 a ex:Sentence ;
    rdfs:label "Общие потери в сражении составили около 65 тысяч человек." .

ex:sentence_4_atomic_0 a ex:AtomicStatement ;
    rdfs:label "Французская армия потеряла 41 тысячу человек" ;
    ex:mentionsObject ex:object_41000_человек,
        ex:object_Французская_армия .

ex:sentence_4_atomic_1 a ex:AtomicStatement ;
    rdfs:label "От 24 до 26 тысяч французов были убиты, ранены или взяты в плен" ;
    ex:mentionsObject ex:object_24000-26000_человек,
        ex:object_Французская_армия .

ex:sentence_4_atomic_2 a ex:AtomicStatement ;
    rdfs:label "15 тысяч французов дезертировали после битвы" ;
    ex:mentionsObject ex:object_15000_человек,
        ex:object_Французская_армия .

ex:sentence_4_context_0 a ex:Sentence ;
    rdfs:label "Союзники потеряли около 24 тысяч человек." .

ex:sentence_4_context_1 a ex:Sentence ;
    rdfs:label "Общие потери составили 65 тысяч человек." .

ex:sentence_5_atomic_0 a ex:AtomicStatement ;
    rdfs:label "Битва при Ватерлоо была одним из самых кровопролитных сражений Наполеоновских войн" ;
    ex:mentionsObject ex:object_Битва_при_Ватерлоо,
        ex:object_Наполеоновские_войны .

ex:sentence_5_atomic_1 a ex:AtomicStatement ;
    rdfs:label "Битва при Ватерлоо стала последней битвой Наполеона" ;
    ex:mentionsObject ex:object_Битва_при_Ватерлоо,
        ex:object_Наполеон .

ex:sentence_5_context_0 a ex:Sentence ;
    rdfs:label "После этого сражения Наполеон был окончательно разбит и сослан на остров Святой Елены." .

ex:sentence_5_context_1 a ex:Sentence ;
    rdfs:label "Сражение закончило эпоху Наполеоновских войн." .

ex:object_Прусская_армия a ex:Object ;
    rdfs:label "Прусская армия" .

ex:object_Битва_при_Ватерлоо a ex:Object ;
    rdfs:label "Битва при Ватерлоо" .

ex:object_Французская_армия a ex:Object ;
    rdfs:label "Французская армия" .

