@prefix ex: <http://example.org/birds#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:BirdsOntology a owl:Ontology ;
    rdfs:label "Birds multimodal annotation ontology"@en .

ex:aboutSpecies a owl:ObjectProperty ;
    rdfs:domain ex:TextMention ;
    rdfs:range ex:BirdSpecies .

