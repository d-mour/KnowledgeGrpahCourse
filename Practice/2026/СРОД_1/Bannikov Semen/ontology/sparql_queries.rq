# Query 1 (Natural language):
# Какие виды птиц представлены во всех трех модальностях:
# текстовые упоминания, аудиосегменты и детекции на изображениях?
PREFIX ex: <http://example.org/birds#>

SELECT ?sid ?latin
WHERE {
  ?sp a ex:BirdSpecies ;
      ex:speciesId ?sid ;
      ex:latinName ?latin .

  FILTER EXISTS { ?m a ex:TextMention ; ex:aboutSpecies ?sp . }
  FILTER EXISTS { ?seg a ex:AudioSegment ; ex:segmentSpecies ?sp . }
  FILTER EXISTS { ?det a ex:BirdDetection ; ex:detectedSpecies ?sp . }
}
ORDER BY ?sid

;

# Query 2 (Natural language):
# Сколько аудиосегментов (голоса птиц) размечено для каждого вида?
PREFIX ex: <http://example.org/birds#>

SELECT ?sid (COUNT(?seg) AS ?segments)
WHERE {
  ?sp a ex:BirdSpecies ; ex:speciesId ?sid .
  ?seg a ex:AudioSegment ; ex:segmentSpecies ?sp .
}
GROUP BY ?sid
ORDER BY ?sid

;

# Query 3 (Natural language):
# Сколько детекций птиц на изображениях есть для каждого вида?
PREFIX ex: <http://example.org/birds#>

SELECT ?sid (COUNT(?det) AS ?detections)
WHERE {
  ?sp a ex:BirdSpecies ; ex:speciesId ?sid .
  ?det a ex:BirdDetection ; ex:detectedSpecies ?sp .
}
GROUP BY ?sid
ORDER BY ?sid

;

# Query 4 (Natural language):
# Какие типы текстовых сущностей чаще всего встречаются?
PREFIX ex: <http://example.org/birds#>

SELECT ?label (COUNT(?m) AS ?count)
WHERE {
  ?m a ex:TextMention ; ex:mentionLabel ?label .
}
GROUP BY ?label
ORDER BY DESC(?count)
