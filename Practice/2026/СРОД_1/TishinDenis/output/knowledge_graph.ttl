ex:Buy a ex:Decision ;
    rdfs:label "BUY"@en .

ex:Podcast a owl:Class ;
    rdfs:label "Подкаст"@ru ;
    rdfs:comment "Эпизод подкаста — источник аудио-сегментов."@ru .

ex:PutOption a owl:Class ;
    rdfs:label "Пут-опцион"@ru ;
    rdfs:subClassOf ex:OptionContract .

ex:pod_macro_weekly_42_seg_1 a ex:PodcastSegment ;
    ex:avgLogprob "-0.21"^^xsd:float ;
    ex:coOccursWith ex:snap_001,
        ex:snap_002 ;
    ex:compressionRatio "1.65"^^xsd:float ;
    ex:duration "4.72"^^xsd:float ;
    ex:endTime "9.1"^^xsd:float ;
    ex:mentionsTicker ex:ticker_SPY ;
    ex:noSpeechProb "0.018"^^xsd:float ;
    ex:partOfPodcast ex:pod_macro_weekly_42 ;
    ex:polarity "bullish"^^xsd:string ;
    ex:segmentIndex 1 ;
    ex:startTime "4.38"^^xsd:float ;
    ex:timestamp "2026-04-15T14:25:04.380000+00:00"^^xsd:dateTime ;
    ex:transcriptText "SPY looks strong here, the bullish setup on the index is hard to ignore."^^xsd:string .

ex:pod_macro_weekly_42_seg_2 a ex:PodcastSegment ;
    ex:avgLogprob "-0.19"^^xsd:float ;
    ex:coOccursWith ex:snap_001,
        ex:snap_002 ;
    ex:compressionRatio "1.7"^^xsd:float ;
    ex:duration "5.1"^^xsd:float ;
    ex:endTime "14.2"^^xsd:float ;
    ex:mentionsTicker ex:ticker_SPY ;
