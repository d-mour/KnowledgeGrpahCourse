@prefix ex: <http://itmo.ru/spy-multimodal#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://itmo.ru/spy-multimodal> a owl:Ontology ;
    rdfs:label "SPY Multimodal Trading Ontology"@en,
        "Онтология мультимодального предсказания торговых сигналов SPY"@ru ;
    rdfs:comment "Онтология для ЛР6: связывает рыночные снимки опционной цепочки SPY, подкаст-транскрипты и торговые сигналы (BUY/SELL/HOLD) в единый граф знаний."@ru .

ex:Hold a ex:Decision ;
    rdfs:label "HOLD"@en .

ex:Sell a ex:Decision ;
    rdfs:label "SELL"@en .

ex:appliesTo a owl:ObjectProperty ;
    rdfs:label "относится к снимку"@ru ;
    rdfs:domain ex:TradingSignal ;
    rdfs:range ex:MarketSnapshot .

ex:ask a owl:DatatypeProperty ;
    rdfs:label "ask"@ru ;
    rdfs:range xsd:float .

ex:askSize a owl:DatatypeProperty ;
    rdfs:label "размер ask"@ru ;
    rdfs:range xsd:integer .

ex:avgLogprob a owl:DatatypeProperty ;
    rdfs:label "средний log-prob ASR"@ru ;
    rdfs:range xsd:float .

ex:bid a owl:DatatypeProperty ;
    rdfs:label "bid"@ru ;
    rdfs:range xsd:float .

ex:bidSize a owl:DatatypeProperty ;
    rdfs:label "размер bid"@ru ;
    rdfs:range xsd:integer .

ex:coOccursWith a owl:ObjectProperty ;
    rdfs:label "со-встречается со снимком"@ru ;
    rdfs:comment "Сегмент подкаста и рыночный снимок попали в общее временное окно."@ru ;
    rdfs:domain ex:PodcastSegment ;
    rdfs:range ex:MarketSnapshot .

ex:compressionRatio a owl:DatatypeProperty ;
    rdfs:label "compression ratio"@ru ;
    rdfs:range xsd:float .

ex:confidence a owl:DatatypeProperty ;
    rdfs:label "уверенность модели"@ru ;
    rdfs:range xsd:float .

ex:decisionLabel a owl:DatatypeProperty ;
    rdfs:label "метка решения"@ru ;
    rdfs:range xsd:string .

ex:delta a owl:DatatypeProperty ;
    rdfs:label "delta"@ru ;
    rdfs:range xsd:float .

ex:duration a owl:DatatypeProperty ;
    rdfs:label "длительность (с)"@ru ;
    rdfs:range xsd:float .

ex:endTime a owl:DatatypeProperty ;
    rdfs:label "конец (с)"@ru ;
    rdfs:range xsd:float .

ex:evidencedBy a owl:ObjectProperty ;
    rdfs:label "обоснован доказательством"@ru ;
    rdfs:comment "Связь сигнала с любым доказательством: подкаст-сегмент, snapshot, опцион."@ru ;
    rdfs:domain ex:TradingSignal .

ex:expiry a owl:DatatypeProperty ;
    rdfs:label "дата экспирации"@ru ;
    rdfs:range xsd:date .

ex:extrinsicValue a owl:DatatypeProperty ;
    rdfs:label "временна́я стоимость"@ru ;
    rdfs:range xsd:float .

ex:gamma a owl:DatatypeProperty ;
    rdfs:label "gamma"@ru ;
    rdfs:range xsd:float .

ex:hasDecision a owl:ObjectProperty ;
    rdfs:label "имеет решение"@ru ;
    rdfs:domain ex:TradingSignal ;
    rdfs:range ex:Decision .

ex:hasOption a owl:ObjectProperty ;
    rdfs:label "содержит опцион"@ru ;
    rdfs:domain ex:MarketSnapshot ;
    rdfs:range ex:OptionContract .

ex:horizonMin a owl:DatatypeProperty ;
    rdfs:label "горизонт (мин)"@ru ;
    rdfs:range xsd:integer .

ex:intrinsicValue a owl:DatatypeProperty ;
    rdfs:label "внутренняя стоимость"@ru ;
    rdfs:range xsd:float .

ex:ivOption a owl:DatatypeProperty ;
    rdfs:label "implied volatility"@ru ;
    rdfs:range xsd:float .

ex:lastPrice a owl:DatatypeProperty ;
    rdfs:label "последняя цена"@ru ;
    rdfs:range xsd:float .

ex:mentionsTicker a owl:ObjectProperty ;
    rdfs:label "упоминает тикер"@ru ;
    rdfs:comment "Связь подкаст-сегмента с упомянутым в нём тикером (NER)."@ru ;
    rdfs:domain ex:PodcastSegment ;
    rdfs:range ex:Ticker .

ex:noSpeechProb a owl:DatatypeProperty ;
    rdfs:label "вероятность отсутствия речи"@ru ;
    rdfs:range xsd:float .

ex:onTicker a owl:ObjectProperty ;
    rdfs:label "относится к тикеру"@ru ;
    rdfs:range ex:Ticker .

ex:optionId a owl:DatatypeProperty ;
    rdfs:label "ID опциона у брокера"@ru ;
    rdfs:range xsd:string .

ex:partOfPodcast a owl:ObjectProperty ;
    rdfs:label "является частью подкаста"@ru ;
    rdfs:domain ex:PodcastSegment ;
    rdfs:range ex:Podcast .

ex:pod_macro_weekly_42_seg_0 a ex:PodcastSegment ;
    ex:avgLogprob "-0.1732"^^xsd:float ;
    ex:compressionRatio "1.72"^^xsd:float ;
    ex:duration "4.38"^^xsd:float ;
    ex:endTime "4.38"^^xsd:float ;
    ex:noSpeechProb "0.032"^^xsd:float ;
    ex:partOfPodcast ex:pod_macro_weekly_42 ;
    ex:polarity "neutral"^^xsd:string ;
    ex:segmentIndex 0 ;
    ex:startTime "0.0"^^xsd:float ;
    ex:timestamp "2026-04-15T14:25:00+00:00"^^xsd:dateTime ;
    ex:transcriptText "Well, of course, no surprises is an important mantra for CFOs."^^xsd:string .

ex:polarity a owl:DatatypeProperty ;
    rdfs:label "полярность"@ru ;
    rdfs:comment "{bullish | bearish | neutral} — извлекается лексическим анализом текста."@ru ;
    rdfs:range xsd:string .

ex:rationale a owl:DatatypeProperty ;
    rdfs:label "обоснование"@ru ;
    rdfs:range xsd:string .

ex:rho a owl:DatatypeProperty ;
    rdfs:label "rho"@ru ;
    rdfs:range xsd:float .

ex:segmentIndex a owl:DatatypeProperty ;
    rdfs:label "индекс сегмента"@ru ;
    rdfs:range xsd:integer .

ex:signal_snap_001 a ex:TradingSignal ;
    ex:appliesTo ex:snap_001 ;
    ex:confidence "0.333"^^xsd:float ;
    ex:decisionLabel "BUY"^^xsd:string ;
    ex:evidencedBy ex:pod_macro_weekly_42_seg_1,
        ex:pod_macro_weekly_42_seg_2,
        ex:pod_macro_weekly_42_seg_3 ;
    ex:hasDecision ex:Buy ;
    ex:horizonMin 60 ;
    ex:onTicker ex:ticker_SPY ;
    ex:rationale "bullish=2, bearish=1, related_segments=3"^^xsd:string ;
    ex:timestamp "2026-04-15T14:30:00+00:00"^^xsd:dateTime .

ex:signal_snap_002 a ex:TradingSignal ;
    ex:appliesTo ex:snap_002 ;
    ex:confidence "0.333"^^xsd:float ;
    ex:decisionLabel "BUY"^^xsd:string ;
    ex:evidencedBy ex:pod_macro_weekly_42_seg_1,
        ex:pod_macro_weekly_42_seg_2,
        ex:pod_macro_weekly_42_seg_3 ;
    ex:hasDecision ex:Buy ;
    ex:horizonMin 60 ;
    ex:onTicker ex:ticker_SPY ;
    ex:rationale "bullish=2, bearish=1, related_segments=3"^^xsd:string ;
    ex:timestamp "2026-04-15T14:31:30+00:00"^^xsd:dateTime .

ex:snapshotVolatility a owl:DatatypeProperty ;
    rdfs:label "волатильность снимка"@ru ;
    rdfs:range xsd:float .

ex:startTime a owl:DatatypeProperty ;
    rdfs:label "начало (с)"@ru ;
    rdfs:range xsd:float .

ex:strike a owl:DatatypeProperty ;
    rdfs:label "страйк"@ru ;
    rdfs:range xsd:float .

ex:theta a owl:DatatypeProperty ;
    rdfs:label "theta"@ru ;
    rdfs:range xsd:float .

ex:timestamp a owl:DatatypeProperty ;
    rdfs:label "временна́я метка"@ru ;
    rdfs:range xsd:dateTime .

ex:transcriptText a owl:DatatypeProperty ;
    rdfs:label "текст транскрипта"@ru ;
    rdfs:range xsd:string .

ex:underlyingPrice a owl:DatatypeProperty ;
    rdfs:label "цена базового актива"@ru ;
    rdfs:range xsd:float .

ex:vega a owl:DatatypeProperty ;
    rdfs:label "vega"@ru ;
    rdfs:range xsd:float .

