    ex:timestamp "2026-04-15T14:25:09.100000+00:00"^^xsd:dateTime ;
    ex:transcriptText "I'd be cautious though, SPY may pull back if volatility spikes again."^^xsd:string .

ex:pod_macro_weekly_42_seg_3 a ex:PodcastSegment ;
    ex:avgLogprob "-0.22"^^xsd:float ;
    ex:coOccursWith ex:snap_001,
        ex:snap_002 ;
    ex:compressionRatio "1.68"^^xsd:float ;
    ex:duration "5.600000000000001"^^xsd:float ;
    ex:endTime "19.8"^^xsd:float ;
    ex:mentionsTicker ex:ticker_SPY ;
    ex:noSpeechProb "0.022"^^xsd:float ;
    ex:partOfPodcast ex:pod_macro_weekly_42 ;
    ex:polarity "bullish"^^xsd:string ;
    ex:segmentIndex 3 ;
    ex:startTime "14.2"^^xsd:float ;
    ex:timestamp "2026-04-15T14:25:14.200000+00:00"^^xsd:dateTime ;
    ex:transcriptText "Overall I am bullish on SPY into next month's expiry."^^xsd:string .

ex:CallOption a owl:Class ;
    rdfs:label "Колл-опцион"@ru ;
    rdfs:subClassOf ex:OptionContract .

ex:OptionContract a owl:Class ;
    rdfs:label "Опционный контракт"@ru ;
    rdfs:comment "Конкретный опционный контракт с greeks, bid/ask, объёмами."@ru .

ex:Ticker a owl:Class ;
    rdfs:label "Тикер"@ru ;
    rdfs:comment "Биржевой тикер актива (например, SPY)."@ru .

ex:Decision a owl:Class ;
    rdfs:label "Торговое решение"@ru ;
    rdfs:comment "Перечислимый класс решений: Buy, Sell, Hold."@ru .

ex:pod_macro_weekly_42 a ex:Podcast ;
    rdfs:label "Macro Weekly Episode 42" ;
    ex:timestamp "2026-04-15T14:25:00+00:00"^^xsd:dateTime .

ex:snap_001 a ex:MarketSnapshot ;
    ex:hasOption ex:snap_001_call_0,
        ex:snap_001_call_1,
        ex:snap_001_put_0 ;
    ex:onTicker ex:ticker_SPY ;
    ex:snapshotVolatility "18.0"^^xsd:float ;
    ex:timestamp "2026-04-15T14:30:00+00:00"^^xsd:dateTime ;
    ex:underlyingPrice "521.34"^^xsd:float .

ex:snap_002 a ex:MarketSnapshot ;
    ex:hasOption ex:snap_002_call_0,
        ex:snap_002_put_0 ;
    ex:onTicker ex:ticker_SPY ;
    ex:snapshotVolatility "19.0"^^xsd:float ;
    ex:timestamp "2026-04-15T14:31:30+00:00"^^xsd:dateTime ;
    ex:underlyingPrice "521.78"^^xsd:float .

ex:MarketSnapshot a owl:Class ;
    rdfs:label "Рыночный снимок"@ru ;
    rdfs:comment "Снимок состояния рынка на конкретный момент времени: цена базового актива, волатильность, опционная цепочка."@ru .

ex:TradingSignal a owl:Class ;
    rdfs:label "Торговый сигнал"@ru ;
    rdfs:comment "Целевая метка модели: решение BUY/SELL/HOLD на конкретный snapshot, обоснованное доказательствами из других модальностей."@ru .

ex:PodcastSegment a owl:Class ;
    rdfs:label "Аудио-сегмент подкаста"@ru ;
    rdfs:comment "Временной отрезок подкаста с транскриптом (Whisper segment)."@ru .

ex:ticker_SPY a ex:Ticker ;
    rdfs:label "SPY" .

