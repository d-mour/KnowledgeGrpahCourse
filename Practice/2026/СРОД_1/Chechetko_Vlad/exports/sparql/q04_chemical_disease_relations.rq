PREFIX ex: <https://example.org/medical-multimodal-kg/>
PREFIX schema: <https://schema.org/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?relation_id ?relation_type ?src_text ?tgt_text WHERE { ?rel a ex:TextRelation ; ex:relation_id ?relation_id ; ex:relation_type ?relation_type ; ex:relationSource ?src ; ex:relationTarget ?tgt . ?src ex:text ?src_text . ?tgt ex:text ?tgt_text . } LIMIT 100