PREFIX ex: <https://example.org/medical-multimodal-kg/>
PREFIX schema: <https://schema.org/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?dataset ?stat_name ?stat_value ?description WHERE { ?s a ex:DatasetStat ; ex:dataset ?dataset ; ex:stat_name ?stat_name ; ex:stat_value ?stat_value ; ex:description ?description . } ORDER BY ?dataset ?stat_name