PREFIX ex: <https://example.org/medical-multimodal-kg/>
PREFIX schema: <https://schema.org/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?doc_id ?split ?source_doc_id ?text WHERE { ?doc a ex:TextDocument ; ex:doc_id ?doc_id ; ex:split ?split ; ex:source_doc_id ?source_doc_id ; schema:text ?text . } LIMIT 20