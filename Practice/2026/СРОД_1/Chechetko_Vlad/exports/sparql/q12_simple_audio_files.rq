PREFIX ex: <https://example.org/medical-multimodal-kg/>
PREFIX schema: <https://schema.org/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?audio_id ?dataset ?file_name ?duration WHERE { ?a a ex:AudioRecord ; ex:audio_id ?audio_id ; ex:dataset ?dataset ; ex:file_name ?file_name . OPTIONAL { ?a ex:duration_sec ?duration . } } LIMIT 50